{
  "expo": {
    "name": "autosense",
    "slug": "autosense",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/autosense-logo.png",
    "scheme": "autosense",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/autosense-logo.png",
      "bundleIdentifier": "com.antoniozhong.autosense"
    },
    "android": {
      "package": "com.antoniozhong.autosense",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/autosense-logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent",
          "toolsButton": false,
          "showMenuAtLaunch": false,
          "skipOnboarding": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/autosense-logo.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-asset",
      "expo-maps"
    ],
    "developmentClient": {
      "silentLaunch": true
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
