{
  "expo": {
    "name": "autosense",
    "slug": "autosense",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/autosense-logo.png",
    "scheme": "autosense",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/autosense-logo.png",
      "bundleIdentifier": "com.antoniozhong.autosense",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AutoSense usa tu ubicación para registrar rutas activas.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "AutoSense usa tu ubicación para registrar rutas cuando el OBD2 está activo.",
        "NSLocationAlwaysUsageDescription": "AutoSense usa tu ubicación en segundo plano para seguir tus viajes cuando el OBD2 está activo.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "package": "com.antoniozhong.autosense",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/autosense-logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent",
          "toolsButton": false,
          "showMenuAtLaunch": false,
          "skipOnboarding": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/autosense-logo.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-asset",
      "expo-maps",
      [
        "expo-image-picker",
        {
          "photosPermission": "AutoSense necesita acceso a tus fotos para actualizar tu imagen de perfil."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AutoSense usa tu ubicación para registrar rutas cuando el OBD2 está activo.",
          "locationAlwaysPermission": "AutoSense usa tu ubicación en segundo plano para seguir tus viajes cuando el OBD2 está activo.",
          "locationWhenInUsePermission": "AutoSense usa tu ubicación para registrar rutas activas.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-image"
    ],
    "developmentClient": {
      "silentLaunch": true
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
