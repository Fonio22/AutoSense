{
  "schemaVersion": 1,
  "profileId": "generic_obd2",
  "version": "1.0.0",
  "minFirmwareVersion": "1.0.0",
  "supportLevel": "partial",
  "vehicleMatch": {
    "make": "*",
    "model": "*",
    "yearStart": 1996,
    "yearEnd": 2099
  },
  "protocol": {
    "bus": "CAN",
    "baud": 500000,
    "requestId": "0x7DF",
    "responseIds": ["0x7E8", "0x7E9", "0x7EA", "0x7EB", "0x7EC", "0x7ED", "0x7EE", "0x7EF"],
    "useIsoTp": true,
    "timeoutMs": 800,
    "retry": 2
  },
  "discovery": {
    "mode01SupportPids": ["00", "20", "40", "60", "80", "A0", "C0"],
    "mode09Pids": ["00", "02", "04", "06", "0A"]
  },
  "signals": [
    { "key": "rpm", "label": "Engine RPM", "mode": "01", "pid": "0C", "unit": "rpm", "formula": "((A*256)+B)/4", "formulaId": "be16_div_4", "pollMs": 500, "required": true, "source": "standard_obd2", "enabledByDefault": true },
    { "key": "speed", "label": "Vehicle Speed", "mode": "01", "pid": "0D", "unit": "km/h", "formula": "A", "formulaId": "identity_a", "pollMs": 500, "required": true, "source": "standard_obd2", "enabledByDefault": true },
    { "key": "coolant", "label": "Coolant Temperature", "mode": "01", "pid": "05", "unit": "C", "formula": "A-40", "formulaId": "temp_a_minus_40", "pollMs": 1000, "required": false, "source": "standard_obd2", "enabledByDefault": true },
    { "key": "engine_load", "label": "Engine Load", "mode": "01", "pid": "04", "unit": "pct", "formula": "A*100/255", "formulaId": "pct_a_255", "pollMs": 1000, "required": false, "source": "standard_obd2", "enabledByDefault": true },
    { "key": "throttle", "label": "Throttle", "mode": "01", "pid": "11", "unit": "pct", "formula": "A*100/255", "formulaId": "pct_a_255", "pollMs": 1000, "required": false, "source": "standard_obd2", "enabledByDefault": true },
    { "key": "map", "label": "Intake Manifold Pressure", "mode": "01", "pid": "0B", "unit": "kPa", "formula": "A", "formulaId": "identity_a", "pollMs": 1000, "required": false, "source": "standard_obd2", "enabledByDefault": true },
    { "key": "intake_air", "label": "Intake Air Temperature", "mode": "01", "pid": "0F", "unit": "C", "formula": "A-40", "formulaId": "temp_a_minus_40", "pollMs": 1500, "required": false, "source": "standard_obd2", "enabledByDefault": true },
    { "key": "ecu_v", "label": "ECU Voltage", "mode": "01", "pid": "42", "unit": "V", "formula": "((A*256)+B)/1000", "formulaId": "be16_div_1000", "pollMs": 1500, "required": false, "source": "standard_obd2", "enabledByDefault": true },
    { "key": "maf", "label": "MAF", "mode": "01", "pid": "10", "unit": "g/s", "formula": "((A*256)+B)/100", "formulaId": "be16_div_100", "pollMs": 2000, "required": false, "source": "standard_obd2", "enabledByDefault": true },
    { "key": "fuel_level", "label": "Fuel Level", "mode": "01", "pid": "2F", "unit": "pct", "formula": "A*100/255", "formulaId": "pct_a_255", "pollMs": 3000, "required": false, "source": "standard_obd2", "enabledByDefault": true }
  ],
  "trackingRules": {
    "startWhen": {
      "speedKmhMin": 3,
      "rpmMin": 500,
      "throttleOrFuelMovementRequired": true
    },
    "stopWhen": {
      "speedKmhMax": 2,
      "idleSeconds": 120
    }
  }
}
