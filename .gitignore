[kK]i[Cc]ad/_autosave-*.kicad_pcb
[kK]i[Cc]ad/*.lck
[kK]i[Cc]ad/fp-info-cache
[kK]i[Cc]ad/*.kicad_prl
[kK]i[Cc]ad/*.kicad_sch-bak
[kK]i[Cc]ad/*.kicad_pcb-bak
[kK]i[Cc]ad/*.kicad_pro-bak
